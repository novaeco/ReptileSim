[gd_scene load_steps=2 format=3]
[ext_resource type="Script" path="res://scripts/ui/UIOverlay.gd" id=1]

[node name="UIOverlay" type="CanvasLayer"]
script = ExtResource("1")

[node name="Margin" type="MarginContainer" parent="."]
anchor_right = 1.0
anchor_bottom = 1.0
offset_left = 16
offset_top = 16
offset_right = -16
offset_bottom = -16

[node name="VBox" type="VBoxContainer" parent="Margin"]
[node name="HBox" type="HBoxContainer" parent="Margin/VBox"]
[node name="Temp" type="Label" parent="Margin/VBox/HBox"]
text = "T: --.- °C"
[node name="Hum" type="Label" parent="Margin/VBox/HBox"]
text = "H: -- %"
[node name="UVI" type="Label" parent="Margin/VBox/HBox"]
text = "UVI: -.--"

[node name="Buttons" type="HBoxContainer" parent="Margin/VBox"]
[node name="Feed" type="Button" parent="Margin/VBox/Buttons"]
text = "Nourrir"
[node name="Drink" type="Button" parent="Margin/VBox/Buttons"]
text = "Abreuver"
[node name="Save" type="Button" parent="Margin/VBox/Buttons"]
text = "Sauver"
[node name="Exit" type="Button" parent="Margin/VBox/Buttons"]
text = "Menu"

[node name="Notifications" type="RichTextLabel" parent="Margin/VBox"]
fit_content = true
scroll_active = false
bbcode_enabled = false

[connection signal="pressed" from="UIOverlay/Margin/VBox/Buttons/Feed" to="." method="_on_Feed_pressed"]
[connection signal="pressed" from="UIOverlay/Margin/VBox/Buttons/Drink" to="." method="_on_Drink_pressed"]
[connection signal="pressed" from="UIOverlay/Margin/VBox/Buttons/Save" to="." method="_on_Save_pressed"]
[connection signal="pressed" from="UIOverlay/Margin/VBox/Buttons/Exit" to="." method="_on_Exit_pressed"]
